---
import { Image } from "astro:assets";
import kenny from "../assets/hero.png";
import A from "./A.astro";
import { buttonVariants } from "./A.astro";
---

<section
  class="reveal-group relative flex min-h-svh flex-col items-center justify-between overflow-hidden bg-[radial-gradient(67.16%_55.88%_at_50%_44.12%,#B26C49_0%,#51220B_100%)] px-6 pt-16 pb-10 lg:min-h-193.5 lg:flex-row lg:px-12 lg:py-13"
>
  <!-- Heading Container -->
  <div
    class="reveal-item absolute top-[20%] z-30 w-full text-center lg:top-[30%] lg:left-12.5 lg:text-left"
  >
    <h1
      class="mb-4 font-sans text-3xl leading-tight font-light text-white lg:text-[44px]"
    >
      Simplifying Complexity.<br />
      <em class="font-bold italic">Designing for Impact.</em>
    </h1>
  </div>

  <!-- Paragraph (Hidden on mobile to match photo, visible on desktop) -->
  <div
    class="reveal-item z-30 hidden max-w-112.5 lg:absolute lg:top-[48%] lg:left-12.5 lg:block"
  >
    <p class="mb-8 text-base leading-relaxed font-light text-white">
      I help global organizations and tech leaders turn complex systems into
      intuitive, high-performance digital products.
    </p>
  </div>

  <!-- Decorative Text / Name Animation (Behind the image) -->
  <div
    class="font-decorative text-cream text-right text-6xl leading-none opacity-50 lg:text-[208px]"
  >
    <div
      class:list={[
        "pointer-events-none absolute top-1/2 left-5 z-10 lg:top-[30%] lg:right-12.5 lg:left-auto",
        "animate-line block",
      ]}
    >
      Kenny
    </div>
    <div
      class:list={[
        "pointer-events-none absolute top-1/2 right-5 z-10 lg:top-[55%] lg:right-12.5 lg:left-auto",
        "animate-line block",
      ]}
    >
      Beltre
    </div>
  </div>

  <!-- Image Container -->
  <div
    class="reveal-up absolute bottom-0 z-20 mt-auto flex w-full justify-center"
  >
    <Image
      src={kenny}
      alt="Kenny Beltre"
      class="aspect-27/37 max-w-100 rounded-2xl object-cover lg:w-134.75 lg:max-w-none"
      loading={"eager"}
    />
  </div>

  <!-- Buttons Container -->
  <div
    class="reveal-item absolute bottom-10 z-30 mt-8 flex flex-wrap items-center justify-center gap-4 lg:left-12.5 lg:mt-0 lg:gap-6"
  >
    <A
      target="_blank"
      href="https://calendly.com/kennymbeltre/letsworktogether"
    >
      Book a strategy call
    </A>

    <button
      onclick="ml('show', 'V0kLj5', true)"
      class={buttonVariants({
        variant: "ghost",
        class: "underline",
      })}
    >
      Download the free guide
    </button>
  </div>
</section>
