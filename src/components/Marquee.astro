---
interface Props {
  speed?: number; // Duration in seconds (higher = slower)
  direction?: "left" | "right";
  pauseOnHover?: boolean;
  gap?: string; // Tailwind gap class, e.g., "gap-10"
}

const {
  speed = 30,
  direction = "left",
  pauseOnHover = true,
  gap = "gap-12",
} = Astro.props;
---

<div
  class="marquee-container overflow-hidden py-4"
  data-speed={speed}
  data-direction={direction}
  data-pause={pauseOnHover.toString()}
>
  <div class:list={["marquee-track flex w-max shrink-0 items-center", gap]}>
    <!-- Slot for the user's content -->
    <slot />
  </div>
</div>

<style>
  /* Prevents children from shrinking */
  .marquee-track > :global(*) {
    flex-shrink: 0;
  }
</style>
